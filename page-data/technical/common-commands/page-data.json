{"componentChunkName":"component---src-templates-blog-post-js","path":"/technical/common-commands/","result":{"data":{"site":{"siteMetadata":{"title":"Yajana Rao"}},"markdownRemark":{"id":"abe16ce4-5037-533c-bcca-d4243b476513","excerpt":"Commands Listing files Path Remove files and folder","html":"<h2>Commands</h2>\n<h3>Listing files</h3>\n<div class=\"gatsby-highlight\" data-language=\"shell\"><pre class=\"language-shell\"><code class=\"language-shell\"><span class=\"token function\">ls</span>\n<span class=\"token function\">dir</span></code></pre></div>\n<h3>Path</h3>\n<div class=\"gatsby-highlight\" data-language=\"shell\"><pre class=\"language-shell\"><code class=\"language-shell\"><span class=\"token builtin class-name\">pwd</span></code></pre></div>\n<h3>Remove files and folder</h3>\n<div class=\"gatsby-highlight\" data-language=\"shell\"><pre class=\"language-shell\"><code class=\"language-shell\"><span class=\"token function\">rm</span> filename.txt\n<span class=\"token function\">rm</span> -r foldername <span class=\"token punctuation\">(</span>Recursive<span class=\"token punctuation\">)</span>\n<span class=\"token function\">rm</span> -rf foldername <span class=\"token punctuation\">(</span>Force<span class=\"token punctuation\">)</span></code></pre></div>","frontmatter":{"title":"Common Commands for everyday use","date":"October 22, 2021","description":"Common Commands for everyday use"}}},"pageContext":{"slug":"/technical/common-commands/","previous":{"fields":{"slug":"/technical/2021-10-1-api-specs/"},"frontmatter":{"title":"API documentation using Swagger"}},"next":{"fields":{"slug":"/technical/2021-12-02-gestures-in-linux/"},"frontmatter":{"title":"Setting up Touchpad Gestures in your Ubuntu Laptop"}}}},"staticQueryHashes":["1105976633","1205699325","1246554614","2841359383","3336116537"]}